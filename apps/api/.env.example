# AgentForge Configuration
# Copy to .env and fill in values

# Database
AGENTFORGE_DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# CORS
AGENTFORGE_CORS_ORIGINS=["http://localhost:3000"]

# Redis (optional - falls back to in-memory)
AGENTFORGE_REDIS_URL=redis://localhost:6379/0

# Ollama (for local AI models)
AGENTFORGE_OLLAMA_BASE_URL=http://localhost:11434
AGENTFORGE_OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# Cloud AI Providers (set if not using Ollama)
# AGENTFORGE_OPENAI_API_KEY=
# AGENTFORGE_ANTHROPIC_API_KEY=
# AGENTFORGE_GOOGLE_API_KEY=
# AGENTFORGE_OPENROUTER_API_KEY=
# AGENTFORGE_GROQ_API_KEY=

# Encryption (MANDATORY for production - 32 bytes, base64 encoded)
# Generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# AGENTFORGE_ENCRYPTION_KEY=

# Authentication (enabled by default - set JWT_SECRET for production)
# AGENTFORGE_AUTH_ENABLED=true
# AGENTFORGE_JWT_SECRET=change-this-to-a-random-secret-at-least-16-chars
# AGENTFORGE_JWT_REFRESH_SECRET=change-this-to-another-random-secret
# AGENTFORGE_JWT_EXPIRE_MINUTES=480
# AGENTFORGE_JWT_REFRESH_EXPIRE_DAYS=7

# Fast Demo Mode
AGENTFORGE_FAST_DEMO_MODE=true
AGENTFORGE_MAX_RETRIES=0
AGENTFORGE_MAX_OUTPUT_TOKENS=512
AGENTFORGE_MAX_CONTEXT_MESSAGES=5
AGENTFORGE_MAX_EXECUTION_TIME=60

# Agent Timeouts
AGENTFORGE_AGENT_TIMEOUT_LEAD=20
AGENTFORGE_AGENT_TIMEOUT_BUILDER=30
AGENTFORGE_AGENT_TIMEOUT_REVIEWER=15
AGENTFORGE_AGENT_TIMEOUT_DELIVER=15

# Log Level
AGENTFORGE_LOG_LEVEL=INFO

# GitHub App integration (PR review bot) — optional
# AGENTFORGE_GITHUB_APP_ID=123456
# Provide the PEM contents inline OR a path to the .pem file:
# AGENTFORGE_GITHUB_APP_PRIVATE_KEY=/secrets/agentforge.private-key.pem
# AGENTFORGE_GITHUB_WEBHOOK_SECRET=generate-a-random-secret
# AGENTFORGE_GITHUB_API_BASE=https://api.github.com
# AGENTFORGE_GITHUB_REVIEW_MODEL=qwen2.5-coder:7b
